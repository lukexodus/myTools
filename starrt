# ────────────────────────────────────────────────
# Rotate check URLs so aggressive polling doesn't exhaust the gateway's state
# table for a single domain (which breaks it in the user's real browser).
CHECK_URLS = [
    "http://neverssl.com",
    "http://httpforever.com",
    "http://stevemorse.org",
    "http://example.com",
    "http://info.cern.ch",
    "http://bbc.com"
]

_url_idx = 0
def get_check_url():
    global _url_idx
    url = CHECK_URLS[_url_idx]
    _url_idx = (_url_idx + 1) % len(CHECK_URLS)
    return url

USER_AGENT       = "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/133.0.0.0 Safari/537.36"

def _get_gateway_url() -> str:
    """
    Return the default gateway as an HTTP URL by reading /proc/net/route.
    Used as a DNS-free fallback when the captive portal blocks all DNS queries.
    Wifidog intercepts HTTP to any host (including raw IPs), so navigating to
    the gateway IP triggers the portal redirect chain without needing DNS.
    Returns None if no default gateway is found.
    """
    try:
        with open('/proc/net/route') as f:
            for line in f:
                fields = line.strip().split()
                if len(fields) < 4:
                    continue
                # Destination=00000000 (default), Flags has RTF_GATEWAY (0x2)
                if fields[1] == '00000000' and int(fields[3], 16) & 0x2:
                    gw_hex = fields[2]
                    gw_ip = socket.inet_ntoa(struct.pack('<L', int(gw_hex, 16)))
                    return f"http://{gw_ip}"
    except Exception:
        pass
    return None
HEADLESS         = True
HEARTBEAT_COARSE = 60      # interval (s) during safe window — just keep-alive pings
HEARTBEAT_FINE   = 5       # interval (s) in danger zone — fast re-auth detection
DANGER_WINDOW    = 60      # switch to fine heartbeat this many seconds before RENEW_EVERY
RENEW_EVERY      = 240     # full probe cycle interval — dynamically adjusted
TIMEOUT_MS       = 45_000

RENEW_MIN              = 60    # never probe more often than this
RENEW_MARGIN           = 0.8   # probe at 80% of avg session lifetime
ADAPT_THRESHOLD        = 3     # update RENEW_EVERY after this many new data points
STARTUP_RENEW_DEFAULT  = 195   # 3m15s — first-cycle RENEW_EVERY (time may have elapsed since last run)
BROWSER_RESTART_CYCLES = 8     # restart Firefox every N cycles (~1h) to free accumulated memory
STATE_FILE = os.path.join(os.path.dirname(os.path.realpath(__file__)), ".starrt_state.json")
# ────────────────────────────────────────────────

PORTAL_HOST = "portal-as.ruijienetworks.com"


def log(msg):
    print(f"[{datetime.datetime.now().strftime('%H:%M:%S')}] {msg}")


# ── probe ─────────────────────────────────────────────────────────────────────

def probe(page) -> bool:
    """
    Navigate to CHECK_URL with networkidle.

    When unauthenticated the full redirect chain is:
      neverssl → 172.16.1.1:2060 → /auth/wifidogAuth/login/?gw_id=...
                                  → (JS) → index.html?timestamp=...&sessionId=...

    networkidle lets the JS-driven redirect fully settle so we land on
    index.html?sessionId=... which is the actual portal page.

    Returns True if we landed on the portal (need auth).
    Returns False if neverssl loaded normally (already connected).
    """
    check_url = get_check_url()
    log(f"Probing {check_url} ...")

    redirected = False

    def on_nav(frame):
        nonlocal redirected
        if frame == page.main_frame and PORTAL_HOST in frame.url:
            redirected = True

    page.on("framenavigated", on_nav)
    try:
        page.goto(check_url, wait_until="networkidle", timeout=TIMEOUT_MS)
    except PlaywrightTimeoutError:
        log("Probe networkidle timed out — checking URL anyway")
    except Exception as e:
        log(f"Probe error: {e}")
    finally:
        page.remove_listener("framenavigated", on_nav)

    if PORTAL_HOST in page.url:
        redirected = True

    if redirected:
        log(f"Portal: {page.url[:90]}")
    else:
        log(f"Connected. URL: {page.url[:60]}")

    return redirected


# ── auth interval tracking + dynamic heartbeat ───────────────────────────────
_auth_times: list[float] = []
_adapt_counter = 0
_startup_renew: float = STARTUP_RENEW_DEFAULT   # restored from state; updated on early expiry


def _load_state():
    """Restore saved average and startup_renew from previous run."""
    global RENEW_EVERY, _startup_renew
    try:
        with open(STATE_FILE) as f:
            data = json.load(f)
        saved_avg = float(data.get("avg_interval", 0))
        if saved_avg > 0:
            new_renew = max(RENEW_MIN, saved_avg * RENEW_MARGIN)
            RENEW_EVERY = new_renew
            log(f"[state] Restored avg session lifetime: {saved_avg:.0f}s "
                f"-> RENEW_EVERY set to {new_renew:.0f}s (heartbeat: coarse={HEARTBEAT_COARSE}s / fine={HEARTBEAT_FINE}s)")
        saved_startup = float(data.get("startup_renew", 0))
        if saved_startup > 0:
            _startup_renew = saved_startup
            log(f"[state] Restored startup_renew: {_startup_renew:.0f}s")
    except FileNotFoundError:
        pass
    except Exception as e:
        log(f"[state] Could not load state: {e}")


def _save_state(avg: float):
    """Persist running average and startup_renew."""
    try:
        with open(STATE_FILE, "w") as f:
            json.dump({
                "avg_interval":  round(avg, 1),
                "startup_renew": round(_startup_renew, 1),
                "updated":       datetime.datetime.now().isoformat(),
            }, f)
    except Exception as e:
        log(f"[state] Could not save state: {e}")


def _record_auth():
    """Called after each fully completed auth. Logs interval stats and adapts RENEW_EVERY."""
    global RENEW_EVERY, _adapt_counter
    now = time.time()
    _auth_times.append(now)
    # Keep only the last 20 timestamps — enough for accurate running average
    if len(_auth_times) > 20:
        _auth_times.pop(0)
    n = len(_auth_times)
    if n < 2:
        return  # first auth, no interval yet

    interval = now - _auth_times[-2]
    avg = (_auth_times[-1] - _auth_times[0]) / (n - 1)
    next_auth = datetime.datetime.fromtimestamp(now + avg).strftime("%H:%M:%S")
    log(
        f"  Auth #{n} | interval since last: {interval:.0f}s "
        f"| running avg: {avg:.0f}s "
        f"(across {n-1} gap{'s' if n > 2 else ''}) "
        f"| next auth ~{next_auth}"
    )

    _adapt_counter += 1
    if _adapt_counter >= ADAPT_THRESHOLD:
        _adapt_counter = 0
        new_renew = max(RENEW_MIN, avg * RENEW_MARGIN)
        if abs(new_renew - RENEW_EVERY) >= 5:
            log(f"  Adapting RENEW_EVERY: {RENEW_EVERY:.0f}s -> {new_renew:.0f}s "
                f"(avg {avg:.0f}s x {RENEW_MARGIN}, heartbeat: coarse={HEARTBEAT_COARSE}s / fine={HEARTBEAT_FINE}s)")
            RENEW_EVERY = new_renew
        _save_state(avg)



def _try_fresh_auth(page, retries: int = 2, dns_blocked: bool = False) -> bool:
    """
    Open a fresh browser CONTEXT (not just a new page) and navigate to
    CHECK_URL to force the gateway redirect chain.

    Why a new CONTEXT and not just a new page in the same context?
    Pages within the same context share HTTP/2 TCP connections via connection
    coalescing. A "fresh" page can still reuse the existing socket to
    neverssl.com, bypass the gateway entirely, and land on neverssl.com without
    a portal redirect. A new context has a fully isolated network stack — own
    connection pool, own cookies — so the gateway sees a brand-new first request.

    dns_blocked: if True, navigate to the default gateway IP directly (bypasses DNS).
                 Wifidog intercepts all HTTP traffic including direct IP requests,
                 so this still triggers the portal redirect chain.

    Returns True if auth succeeded (gateway confirmed via dict.gov.ph redirect).
    """
    browser = page.context.browser
    # When DNS is blocked by an aggressive portal, domain names won't resolve.
    # Navigate to the gateway IP directly — wifidog intercepts HTTP by IP too.
    if dns_blocked:
        gw_url = _get_gateway_url()
        if not gw_url:
            # heartbeat() should have already verified gateway exists before
            # calling us with dns_blocked=True, but handle it defensively.
            log("  DNS blocked but no gateway found — network not ready, backing off")
            return _NETWORK_NOT_READY
        # On Ruijie systems, hitting the gateway IP directly loads the admin GUI,
        # not the captive portal. To trigger the intercept, we must send an HTTP
        # request to a foreign IP. This bypasses DNS but still gets intercepted.
        check_url = "http://1.1.1.1"
        log(f"  DNS blocked — using external IP directly to trigger intercept: {check_url}")
    else:
        check_url = get_check_url()
    ctx_kwargs = dict(
        viewport={"width": 640, "height": 480},
        user_agent=USER_AGENT,
        locale="en-US",
        timezone_id="Asia/Manila",
        ignore_https_errors=True,
    )
    for attempt in range(1, retries + 1):
        fresh_ctx = None
        fresh = None
        try:
            # Setting up a new context and route can hang if the browser IPC is wedged
            # due to an immediate network interface drop (like ENETUNREACH).
            try:
                fresh_ctx = browser.new_context(**ctx_kwargs)
                fresh_ctx.set_default_timeout(15_000)  # strict timeout for everything in this context
                fresh_ctx.route("**/*.{png,jpg,jpeg,gif,svg,webp,ico,avif,mp4,webm}",
                                lambda route: route.abort())
                fresh = fresh_ctx.new_page()
            except Exception as e:
                log(f"  [fresh#{attempt}] context setup failed (network bounce?): {e}")
                continue

            # Wait for commit (headers received, URL changed to neverssl or portal).
            # Chromium often throws ERR_NETWORK_CHANGED and aborts if the network interface
            # bounces exactly during a wait. Catching it and waiting for the URL anyway
            # is more robust.
            try:
                fresh.goto(check_url, wait_until="commit", timeout=15_000)
            except Exception as eval_e:
                err_str = str(eval_e)
                if dns_blocked and "ERR_ADDRESS_UNREACHABLE" in err_str:
                    # Gateway IP unreachable + DNS blocked = network interface
                    # hasn't gotten its IP/route yet (DHCP still in progress).
                    # This is NOT a captive portal — just wait for network to come up.
                    log(f"  [fresh#{attempt}] Gateway unreachable — network still coming up, backing off")
                    return False
                log(f"  [fresh#{attempt}] goto error (ignoring if portal loads): {eval_e}")

            # Instead of networkidle (which hangs if a tracking pixel is stuck),
            # explicitly wait for the portal URL pattern.
            try:
                fresh.wait_for_url(re.compile(r'sessionId=', re.IGNORECASE), timeout=15_000)
                log(f"  [fresh#{attempt}] sessionId found — authenticating...")
                success = do_auth(fresh)
                if success:
                    log("  Fresh-page auth successful — internet restored")
                    return True
                if verify_connectivity():
                    log("  Fresh-page auth successful — internet restored")
                    return True
                else:
                    log(f"  [fresh#{attempt}] auth done but verify failed")
            except PlaywrightTimeoutError:
                log(f"  [fresh#{attempt}] No sessionId (URL: {fresh.url[:60]})")

        finally:
            for obj in (fresh, fresh_ctx):
                if obj:
                    try:
                        obj.close()
                    except Exception:
                        pass

    log("  _try_fresh_auth: retries exhausted — caller will re-probe")
    return False



def do_auth(page):

    """
    Authenticate by calling the portal API directly — no UI interaction needed.

    Confirmed auth flow (from network inspection):
      1. POST https://portal-as.ruijienetworks.com/api/auth/general
         body: {"lang":"en_US","authType":"pass","sessionId":"<ID>"}
         → response: {"logonUrl":"http://172.16.1.1:2060/wifidog/auth?token=<ID>&phoneNumber=<MAC>"}
      2. GET logonUrl → 302 → gateway authorizes MAC → internet live

      The sessionId is embedded in the page URL:
        .../index.html?timestamp<TS>&sessionId=<32-hex-chars>
    """
    log(f"Auth on: {page.url[:90]}")

    # ── Extract sessionId from URL ──
    m = re.search(r'sessionId=([a-f0-9]{32,})', page.url, re.IGNORECASE)
    if not m:
        log("  No sessionId in URL — cannot auth directly.")
        log(f"  URL: {page.url}")
        return
    session_id = m.group(1)
    log(f"  sessionId: {session_id[:8]}...{session_id[-4:]}")

    # ── POST /api/auth/general via same-origin fetch in the page context ──
    log("  Calling /api/auth/general ...")
    result = page.evaluate(f"""
        async () => {{
            try {{
                const resp = await fetch('/api/auth/general', {{
                    method: 'POST',
                    headers: {{
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': '*/*'
                    }},
                    body: JSON.stringify({{
                        lang: 'en_US',
                        authType: 'pass',
                        sessionId: '{session_id}'
                    }})
                }});
                const data = await resp.json();
                return {{ ok: true, data: data }};
            }} catch(e) {{
                return {{ ok: false, error: e.toString() }};
            }}
        }}
    """)

    if not result.get("ok"):
        log(f"  API call failed: {result.get('error')}")
        return

    data = result.get("data", {})
    log(f"  API response: {str(data)[:200]}")

    logon_url = (
        data.get("logonUrl")
        or (data.get("data") or {}).get("logonUrl")
        or (data.get("result") or {}).get("logonUrl")   # ← actual response path
    )

    # ── Navigate to logonUrl → tells gateway to unblock MAC ──
    if logon_url:
        log(f"  Following logonUrl: {logon_url}")
        try:
            page.goto(logon_url, wait_until="commit", timeout=15_000)
            log(f"  Gateway response URL: {page.url[:80]}")
        except PlaywrightTimeoutError:
            log("  logonUrl timed out (gateway may still have processed the token)")
        except Exception as e:
            log(f"  logonUrl error: {e}")
    else:
        log(f"  WARNING: No logonUrl in response — gateway not notified")

    time.sleep(1)
    log(f"Auth done. URL: {page.url[:80]}")

    if logon_url:
        _record_auth()
        return True   # gateway confirmed via redirect — internet is live
    return False

# ── verify ────────────────────────────────────────────────────────────────────

# Sentinel returned by verify_connectivity() when DNS fails but the interface
# is still up. Indicates the portal may be blocking DNS aggressively instead
# of redirecting — should try re-auth rather than wait.
_DNS_BLOCKED = "dns_blocked"

# Sentinel returned by _try_fresh_auth() when there is no default gateway yet
# (DHCP still in progress after iwd reassociation). Caller should stay in the
# danger zone and retry instead of triggering a full re-probe cycle.
_NETWORK_NOT_READY = "not_ready"

# Timestamp of the last ERR_NETWORK_CHANGED event. Used to apply a cooldown
# before treating DNS failure as a portal expiry signal — DNS can take a few
# seconds to propagate after DHCP settles, even though the route is already up.
_ROAM_COOLDOWN_S = 30   # seconds to wait after a network change before auth
_last_network_change: float = 0.0


def verify_connectivity():
    """
    Check internet access using Python's urllib directly (not the browser).

    Returns:
      True          — connected (check URL loaded without portal redirect)
      False         — portal redirect detected (session expired, re-auth needed)
      None          — network physically unreachable (errno 101 ENETUNREACH /
                      interface down). Caller should WAIT, not re-auth.
      _DNS_BLOCKED  — DNS resolution failed (errno -3) but interface may still
                      be up. Some portals block DNS on expiry instead of
                      redirecting. Caller may attempt re-auth.

    Distinguishing None from False/_DNS_BLOCKED is critical: errno 101 means
    the interface has no route at all, so the portal is also unreachable and
    any re-auth attempt would instantly fail.
    """
    try:
        check_url = get_check_url()
        resp = urllib.request.urlopen(
            urllib.request.Request(check_url, headers={"User-Agent": USER_AGENT}),
            timeout=8
        )
        final_url = resp.geturl()
        if PORTAL_HOST in final_url:
            log("  Verify: BLOCKED (redirected to portal)")
            return False
        log(f"  Verify: CONNECTED ({final_url[:50]})")
        return True
    except urllib.error.URLError as e:
        reason = getattr(e, 'reason', e)
        errno_val = getattr(reason, 'errno', None)
        if errno_val == 101:  # ENETUNREACH — no route, interface down
            log(f"  Verify: UNREACHABLE (network down: {reason})")
            return None
        if errno_val == -3:   # EAI_AGAIN / NXDOMAIN — DNS blocked by portal
            log(f"  Verify: DNS blocked (portal may be intercepting DNS: {reason})")
            return _DNS_BLOCKED
        log(f"  Verify error: {e}")
        return None   # any other hard error — wait, don't assume expired
    except Exception as e:
        log(f"  Verify error: {e}")
        return None


# ── heartbeat ─────────────────────────────────────────────────────────────────

def heartbeat(page, remaining: float = 0) -> bool:
    """
    Ping CHECK_URL (commit only — fast) to check if session is still live.

    If portal redirect detected:
      - Wait up to 15s for JS to land on index.html?sessionId=...
      - Call do_auth() directly (no need to break to probe)
      - Return False (session re-established inline)

    Returns True only if re-auth failed and caller must run a full probe.
    """
    rem_m, rem_s = divmod(max(0, int(remaining)), 60)
    check_url = get_check_url()
    log(f"Heartbeat → {check_url}  [{rem_m}m{rem_s:02d}s until predicted expiry]")

    redirected = False

    def on_nav(frame):
        nonlocal redirected
        if frame == page.main_frame and PORTAL_HOST in frame.url:
            redirected = True

    timed_out = False
    page.on("framenavigated", on_nav)
    try:
        page.goto(check_url, wait_until="commit", timeout=15_000)
        # neverssl 302s to a random subdomain, which the gateway may then intercept
        # and redirect to the portal — all happening AFTER commit. A short wait
        # with the listener still active catches this follow-up redirect chain.
        try:
            page.wait_for_load_state("networkidle", timeout=8_000)
        except Exception:
            pass  # timeout is fine — we just want any extra navigations to settle
    except Exception as e:
        log(f"  Heartbeat error: {e}")
        timed_out = True
        # ERR_NETWORK_CHANGED means iwd roamed to a different AP — the network
        # interface itself changed. DNS failure here is a transient side-effect
        # of DHCP renegotiation, NOT the portal blocking DNS. Record the time
        # so the cooldown check below can suppress false auth triggers.
        if "ERR_NETWORK_CHANGED" in str(e):
            global _last_network_change
            _last_network_change = time.time()
            page._starrt_network_changed = True
    finally:
        page.remove_listener("framenavigated", on_nav)

    if PORTAL_HOST in page.url:
        redirected = True

    if not redirected:
        if timed_out:
            # page.url may be stale — use urllib to determine real state
            v = verify_connectivity()
            if v is True:
                log("  Heartbeat timeout but verify OK — session still live")
                return False
            elif v is None:
                # Network interface is down (ENETUNREACH, errno 101).
                # Don't treat as session expired — portal is also unreachable.
                # Just wait; the loop will retry on the next heartbeat.
                log("  Heartbeat timeout + network down — waiting (not re-authing)")
                return False
            elif v is _DNS_BLOCKED:
                # DNS is being blocked but interface is still up.
                # Discriminate between two cases:
                #   a) iwd roaming: DHCP not done, no default gateway yet → WAIT
                #   b) portal expired: DHCP fine, only external DNS blocked → AUTH
                # The gateway presence in /proc/net/route is the clean signal.
                # Also apply a cooldown after ERR_NETWORK_CHANGED: even when the
                # gateway comes back quickly, DNS takes a few seconds to propagate
                # after DHCP settles. Without a cooldown, we'd false-trigger auth.
                network_changed = getattr(page, '_starrt_network_changed', False)
                page._starrt_network_changed = False  # reset
                if network_changed:
                    log("  Heartbeat timeout + DNS blocked after network change — waiting for DHCP to settle")
                    return False
                secs_since_roam = time.time() - _last_network_change
                if secs_since_roam < _ROAM_COOLDOWN_S:
                    log(f"  Heartbeat timeout + DNS blocked (in roam cooldown, {secs_since_roam:.0f}s/{_ROAM_COOLDOWN_S}s) — waiting")
                    return False
                gw = _get_gateway_url()
                if not gw:
                    log("  Heartbeat timeout + DNS blocked + no gateway — DHCP still settling, waiting")
                    return False
                # Gateway is up, DHCP is done — only the portal is blocking DNS.
                log("  Heartbeat timeout + DNS blocked — assuming portal, attempting re-auth")
                redirected = True
                page._starrt_dns_blocked = True
            else:  # v is False — urllib confirmed portal redirect
                log("  Heartbeat timeout + verify: portal redirect — session expired")
                redirected = True
        else:
            log(f"  Heartbeat: OK → {page.url[:60]}")
            return False

    log("  Heartbeat: session expired — portal redirect!")

    # ── Open a FRESH page to get sessionId — avoids TCP connection pool reuse ──
    log("  Attempting fresh-page re-auth...")
    dns_blocked = getattr(page, '_starrt_dns_blocked', False)
    page._starrt_dns_blocked = False   # reset
    result = _try_fresh_auth(page, dns_blocked=dns_blocked)
    if result is True:
        _blank_page(page)   # auth was done on a separate context; free main page DOM
        return False   # internet restored inline
    if result is _NETWORK_NOT_READY:
        log("  Network not ready (DHCP pending) — staying in danger zone, retrying")
        return False   # stay in danger zone, don't trigger full re-probe

    # Clean the main page so probe() doesn't pick up stale framenavigated events
    try:
        page.goto("about:blank", wait_until="commit", timeout=5_000)
    except Exception:
        pass
    return True


# ── browser helpers ──────────────────────────────────────────────────────────

def _blank_page(page) -> None:
    """
    Navigate the main page to about:blank to release the DOM, JS heap, images,
    and layout tree from Firefox's memory. The page stays open but holds nothing.
    Called after every successful auth since the next navigation will be a fresh
    probe or heartbeat anyway.
    """
    try:
        page.goto("about:blank", wait_until="commit", timeout=5_000)
    except Exception:
        pass


def _launch_browser(p):
    """
    Launch chromium_headless_shell (falls back to chromium) with memory-optimized
    settings and return (browser, context, page).
    Called at startup and for periodic restarts to reset accumulated memory.

    Key flags:
    - chromium_headless_shell   : stripped Chromium binary without UI chrome
    - --single-process          : renderer in same process — eliminates child processes
    - --disable-gpu             : no GPU compositing needed for headless
    - --disable-dev-shm-usage   : avoids /dev/shm OOM crashes
    - --js-flags=--max-old-space-size=64 : cap V8 heap at 64MB
    - --disk-cache-size=0       : no disk cache
    - image route               : block images/media — not needed for auth flow
    """
    # chromium_headless_shell is a stripped Chromium build available in Playwright 1.46+.
    # Falls back to full Chromium on older versions.
    browser_type = getattr(p, 'chromium_headless_shell', p.chromium)
    browser = browser_type.launch(
        headless=HEADLESS,
        args=[
            "--disable-gpu",
            "--disable-dev-shm-usage",
            "--disable-extensions",
            "--disable-component-extensions-with-background-pages",
            "--disable-background-networking",
            "--disable-default-apps",
            "--no-first-run",
            "--disk-cache-size=0",
            "--media-cache-size=0",
            "--js-flags=--max-old-space-size=64",
        ]
    )
    context = browser.new_context(
        viewport={"width": 640, "height": 480},
        user_agent=USER_AGENT,
        locale="en-US",
        timezone_id="Asia/Manila",
        ignore_https_errors=True,
    )
    # Block images and media globally — not needed for the auth flow
    context.route("**/*.{png,jpg,jpeg,gif,svg,webp,ico,avif,mp4,webm}",
                  lambda route: route.abort())
    return browser, context, context.new_page()


# ── main ──────────────────────────────────────────────────────────────────────

def main():
    global _startup_renew
    print("Ruijie captive portal keep-alive\n")
    _load_state()

    with sync_playwright() as p:
        browser, context, page = _launch_browser(p)
        cycle = 0

        try:
            need_verify = False
            first_cycle_authed = False   # True only if cycle 1's initial probe needed auth
            while True:
                cycle += 1

                # Periodic browser restart — frees JS engine heap fragmentation,
                # accumulated connection/SSL state, and other leaks GC can't reclaim.
                if cycle > 1 and (cycle - 1) % BROWSER_RESTART_CYCLES == 0:
                    log(f"[memory] Restarting browser (cycle {cycle}) — freeing accumulated memory...")
                    try:
                        context.close()
                        browser.close()
                    except Exception as e:
                        log(f"[memory] Error closing browser: {e}")
                    browser, context, page = _launch_browser(p)
                    log("[memory] Browser relaunched — memory reset")

                print(f"\n{'='*60}\nCycle {cycle} — {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n{'='*60}")

                # Always re-probe via neverssl to get a fresh portal URL with sessionId.
                # The /auth/wifidogAuth/login/ intermediary page has no sessionId so
                # auth won't work there — we need index.html?sessionId=... specifically.
                needs_auth = probe(page)

                if needs_auth:
                    do_auth(page)
                    _blank_page(page)   # free dict.gov.ph DOM — next nav is a heartbeat anyway
                    if cycle == 1:
                        first_cycle_authed = True

                # Only verify connectivity if the previous heartbeat loop detected a session
                # expiry. On a fresh start (or after a clean cycle), neverssl loading without
                # a portal redirect is sufficient proof of connectivity.
                if not needs_auth and need_verify:
                    need_verify = False
                    v = verify_connectivity()
                    if v is False:
                        log("Probe said Connected but verify: portal redirect — trying fresh-page auth")
                        if not _try_fresh_auth(page):
                            needs_auth = probe(page)
                            if needs_auth:
                                do_auth(page)
                                _blank_page(page)
                    elif v is None:
                        log("Probe said Connected but network unreachable — waiting for network")

                # ── Two-phase heartbeat loop ──────────────────────────────────
                # Cycle 1 uses startup_renew (shorter) since time may have elapsed
                # since the program last ran. Subsequent cycles use RENEW_EVERY.
                # Coarse: every HEARTBEAT_COARSE seconds while session is young.
                # Fine:   every HEARTBEAT_FINE seconds once within DANGER_WINDOW.
                # Uses wall-clock time so heartbeat execution cost is accounted for.
                need_verify = False
                in_danger_zone = False
                effective_renew = _startup_renew if cycle == 1 else RENEW_EVERY
                # Anchor to actual last auth time so elapsed is correct across probes.
                # If probe said "Connected" (no auth this cycle), session has been alive
                # since _auth_times[-1] — the elapsed reflects that and danger zone
                # triggers at the right real-world moment without resetting.
                if _auth_times:
                    cycle_start = _auth_times[-1]
                elif cycle == 1 and not needs_auth:
                    # Startup: already connected but no auth history — session age unknown.
                    # Enter danger zone immediately (fine heartbeats) since the session
                    # could be near expiry. Only exit danger zone after a real auth.
                    cycle_start = time.time() - (effective_renew - DANGER_WINDOW)
                    in_danger_zone = True
                    log("[startup] Already connected, session age unknown — entering danger zone immediately")
                else:
                    cycle_start = time.time()
                if cycle == 1:
                    log(f"[startup] Using startup_renew={effective_renew:.0f}s for cycle 1 (vs RENEW_EVERY={RENEW_EVERY:.0f}s)")
                while True:
                    elapsed = time.time() - cycle_start
                    if elapsed >= effective_renew:
                        # Past predicted expiry — check network before attempting auth
                        v = verify_connectivity()
                        if v is None:
                            # Physical network down — portal unreachable, just wait
                            log(f"Predicted expiry reached ({elapsed:.0f}s) but network down — waiting in danger zone")
                            cycle_start = time.time() - (effective_renew - DANGER_WINDOW)
                            in_danger_zone = True
                            continue
                        if v is _DNS_BLOCKED:
                            # DNS blocked. Check if gateway exists to distinguish
                            # iwd roaming (no gateway yet) from portal blocking (gateway up).
                            if not _get_gateway_url():
                                log(f"Predicted expiry reached ({elapsed:.0f}s) but DHCP still settling — waiting")
                                cycle_start = time.time() - (effective_renew - DANGER_WINDOW)
                                in_danger_zone = True
                                continue
                            # Gateway up, portal is blocking DNS — auth via gateway IP
                            log(f"Predicted expiry reached ({elapsed:.0f}s) — trying fresh-page auth via gateway IP")
                            if _try_fresh_auth(page, dns_blocked=True):
                                cycle_start = time.time()
                                in_danger_zone = False
                                effective_renew = RENEW_EVERY
                                _blank_page(page)
                                log("Heartbeat re-authed inline — cycle timer reset, back to safe zone")
                                continue
                            log("Session still alive past prediction — staying in danger zone")
                            cycle_start = time.time() - (effective_renew - DANGER_WINDOW)
                            in_danger_zone = True
                            continue
                        log(f"Predicted expiry reached ({elapsed:.0f}s) — trying fresh-page auth before re-probe")
                        if _try_fresh_auth(page):
                            # Session was already expired and we re-authed inline
                            cycle_start = time.time()
                            in_danger_zone = False
                            effective_renew = RENEW_EVERY
                            _blank_page(page)   # free DOM after inline re-auth
                            log("Heartbeat re-authed inline — cycle timer reset, back to safe zone")
                            continue
                        # Session still alive past prediction — stay in danger zone.
                        log("Session still alive past prediction — staying in danger zone")
                        cycle_start = time.time() - (effective_renew - DANGER_WINDOW)
                        in_danger_zone = True
                        continue
                    remaining = effective_renew - elapsed
                    if remaining <= DANGER_WINDOW:
                        if not in_danger_zone:
                            log(f"Entering danger zone ({remaining:.0f}s left) — heartbeat every {HEARTBEAT_FINE}s")
                            in_danger_zone = True
                        sleep_for = HEARTBEAT_FINE
                    else:
                        sleep_for = HEARTBEAT_COARSE

                    time.sleep(sleep_for)
                    remaining = max(0.0, effective_renew - (time.time() - cycle_start))
                    auth_count_before = len(_auth_times)
                    need_full_probe = heartbeat(page, remaining)
                    if len(_auth_times) > auth_count_before:
                        # Inline re-auth — anchor timer to now, back to safe zone
                        cycle_start = time.time()
                        in_danger_zone = False
                        effective_renew = RENEW_EVERY
                        _blank_page(page)   # free DOM after inline re-auth
                        log("Heartbeat re-authed inline — cycle timer reset, back to safe zone")
                    if need_full_probe:
                        real_elapsed = time.time() - cycle_start
                        if (not in_danger_zone and cycle == 1
                                and first_cycle_authed
                                and real_elapsed < _startup_renew):
                            old = _startup_renew
                            _startup_renew = max(RENEW_MIN, real_elapsed)
                            log(f"[startup] Early expiry at {real_elapsed:.0f}s — startup_renew: {old:.0f}s -> {_startup_renew:.0f}s")
                        need_verify = True
                        log("Inline re-auth failed — doing full re-probe")
                        break

        except KeyboardInterrupt:
            print("\nCtrl+C received — shutting down gracefully...")
        except Exception as e:
            print(f"\nFatal: {e}")
            import traceback; traceback.print_exc()
        finally:
            # ── flush state on any exit (Ctrl+C, crash, or normal end) ──
            n = len(_auth_times)
            if n >= 2:
                avg = (_auth_times[-1] - _auth_times[0]) / (n - 1)
                _save_state(avg)
                uptime = _auth_times[-1] - _auth_times[0]
                print(f"\nSession summary:")
                print(f"  Total auths   : {n}")
                print(f"  Uptime tracked: {uptime/60:.1f} min")
                print(f"  Avg interval  : {avg:.0f}s  (saved to state file)")
            elif n == 1:
                print(f"\nOnly 1 auth recorded — not enough data to save average.")
            context.close()
            browser.close()
            print("Cleaned up.")


if __name__ == "__main__":
    main()
